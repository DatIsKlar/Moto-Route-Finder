{
  "MaxUploadSizeBytes": 1073741824,

  "RouteGeneration": {
    // --- Routing ---
    "MaxRouteAttempts": 3,                // How many generation attempts before giving up
    "MaxRepetitionRatio": 0.05,           // Max fraction of route allowed to retrace itself (5%)
    "IdleTimeoutSeconds": 120,            // Seconds of inactivity before map is unloaded from memory
    "HeartbeatTimeoutSeconds": 60,        // Seconds without client heartbeat before map is unloaded

    // --- Quality scoring weights (must sum to ~1.0) ---
    "RepetitionWeight": 0.3529,           // Weight given to route repetition when scoring quality
    "CircularityWeight": 0.2353,          // Weight given to route circularity (compass spread)
    "CurvatureWeight": 0.1176,            // Weight given to road curvature (twistiness)
    "RoadTypeWeight": 0.1765,             // Weight given to scenic/preferred road types
    "DistAccuracyWeight": 0.1176,         // Weight given to how close route matches target distance

    // --- Quality scoring parameters ---
    "CurvatureSweetSpot": 0.001,          // Ideal curvature rad/meter for max score (legacy Gaussian)
    "CurvatureSigma": 0.003,              // Gaussian width for curvature scoring (legacy)
    "AcceptableRoadCreditFactor": 0.6,    // Fraction of acceptable-quality roads that count toward road type score

    // --- Curvature plateau (section 17) ---
    "CurvatureRampStartRad": 0.0005,      // Below this: score ramps up from CurvatureMinScore
    "CurvaturePlateauStartRad": 0.0018,   // Start of 100% plateau (best scoring zone)
    "CurvaturePlateauEndRad": 0.0060,     // End of 100% plateau
    "CurvatureExcessiveRad": 0.0120,      // Above this: score drops off (too twisty)
    "CurvatureMinScore": 20.0,            // Minimum score for very low or very high curvature

    // --- Circularity (section 18) ---
    "MaxBearingSpreadDegrees": 270,        // Max bearing spread used for normalization (higher = less saturated)

    // --- Forward loop (RouteBuilder) ---
    "ForwardLoopTargetRatio": 0.85,       // Fraction of target distance to aim for on forward leg
    "ReturnDistanceCapMultiplier": 1.4,   // Max return leg distance as multiple of forward leg
    "EarlyAbortFailureRatio": 0.6,        // Abort forward leg if quality drops below this ratio
    "EarlyAbortDistanceRatio": 0.4,       // Abort forward leg if covered less than this fraction of target
    "MinWaypointDistanceM": 200,           // Minimum distance between consecutive waypoints (meters)
    "BacktrackingBearingDelta": 150,       // Bearing delta threshold for detecting backtracking
    "MaxWaypointDistanceRatio": 0.40,      // Max waypoint spacing as fraction of target distance
    "EdgeDensityCheckRadiusM": 5000,       // Radius for edge density checks (meters)
    "EdgeDensityThreshold": 25,            // Min edges in density radius to consider area well-connected
    "CascadeDetectionProximityM": 5000,    // Proximity threshold for cascade failure detection (meters)
    "EarlyRepetitionOverlapThreshold": 0.12, // Overlap threshold for early repetition detection
    "FixPipelineTimeoutMs": 8000,          // Timeout for the route fix pipeline (milliseconds)

    // --- Homing ---
    "HomingPerpendicularOffsetM": 1500,    // Perpendicular offset distance for homing waypoints (meters)
    "MaxHomingAngleAttempts": 13,          // Max angle attempts when placing homing waypoints
    "HomingAngleStepDegrees": 5,           // Angle step between homing attempts (degrees)
    "MinHomingSegmentDistanceKm": 3,       // Minimum homing segment distance (km)
    "HomingOverlapThreshold": 0.20,        // Max overlap allowed for homing segments

    // --- Alternative path (AlternativePathFinder) ---
    "MaxShareFactor": 0.10,                // Max fraction of primary path that alternative can share
    "EstimatedDetourFactor": 1.6,          // Estimated detour factor for alternative path planning
    "DistanceCapMultiplier": 1.3,          // Max alternative distance as multiple of direct distance
    "CorridorWidthPrimary": 1000,          // Width of primary path corridor for edge blocking (meters)
    "CorridorWidthSecondary": 700,         // Width of secondary path corridor (meters)
    "EdgePenaltyFactor": 10.0,             // Penalty multiplier for blocked edges in alternative search
    "MinimumSpreadThreshold": 200.0,       // Minimum spread distance between primary and alternative (meters)
    "PerpendicularOffsetFraction": 0.6,    // Fraction of distance used for perpendicular offset
    "OverlapAcceptanceThreshold": 0.15,    // Max overlap ratio accepted for alternative paths
    "TurnaroundRandomOffsetDegrees": 30,   // Random offset added to turnaround point selection (degrees)
    "TurnaroundDistanceVariation": 0.2,     // Random distance variation for turnaround point (fraction)

    // --- Turnaround candidate scoring (section 13c) ---
    "TurnaroundDensityPenaltyWeight": 300, // Penalty weight for low edge density at turnaround candidates
    "TurnaroundAvoidBearingPenaltyWeight": 200, // Penalty weight for unfavorable bearing at turnaround

    // --- Return path penalty escalation ---
    "VeryHighPenaltyFactor": 20.0,         // Edge penalty factor at very_high escalation tier
    "HighReturnPenaltyFactor": 8.0,        // Edge penalty factor at high escalation tier
    "LowPenaltyFallbackFactor": 3.0,       // Edge penalty factor at low/fallback tier
    "ShorterReturnPenaltyFactor": 5.0,     // Penalty factor for routes shorter than target
    "GraduatedPenaltyBase": 5.0,           // Base penalty for graduated escalation
    "GraduatedPenaltyStep": 5.0,           // Step increment per escalation level
    "PushFallbackPenaltyFactor": 5.0,      // Penalty factor when using push-fallback strategy
    "PushFallbackMinDistanceM": 1500,      // Minimum push distance for fallback (meters)
    "PushFallbackDistanceMultiplier": 2.0,  // Push distance multiplier for fallback strategy

    // --- Start-funnel overlap exclusion ---
    "StartFunnelRadiusM": 500,             // Radius around start point excluded from overlap scoring (meters)

    // --- Triangle loop ---
    "TriangleLoopEnabled": false,          // Enable triangle loop mode (experimental)
    "TriangleLegDistanceFraction": 0.33,   // Fraction of target distance for each triangle leg

    // --- Plateau scoring ---
    "PlateauNormalizationDivisor": 5.0,    // Divisor for plateau length normalization
    "MinPlateauLength": 3,                 // Minimum plateau length for scoring consideration

    // --- Repetition tiebreaker ---
    "RepetitionTiebreakerRatio": 1.05,     // Ratio threshold for tiebreaking candidates by repetition
    "OvershootThresholdMultiplier": 1.5,   // Max allowed overshoot as multiple of target distance

    // --- Out-and-back overlap gate ---
    "OutAndBackOverlapThresholdM": 2000,   // Max out-and-back overlap distance (meters) before rejection

    // --- Early-accept quality floor ---
    "EarlyAcceptQualityScore": 90          // Minimum QualityScore to trigger early acceptance (skip remaining attempts)
  }
}
